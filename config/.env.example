# WiFi Launchpad Configuration
# Copy this file to .env and update with your values

# Application Settings
APP_NAME=WiFi-Launchpad
APP_VERSION=1.0.0
LOG_LEVEL=INFO
DEBUG=false

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wifi_db
DB_USER=your_db_user
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# Network Adapters
# Primary monitoring adapter
MONITOR_INTERFACE=wlan0
# Secondary injection adapter  
INJECTION_INTERFACE=wlan2mon
# Management/connectivity adapter
MANAGEMENT_INTERFACE=wlan1

# GPU Server Configuration (for distributed cracking)
GPU_SERVER_ENABLED=false
GPU_SERVER_HOST=
GPU_SERVER_PORT=22
GPU_SERVER_USER=
GPU_SERVER_KEY_PATH=~/.ssh/gpu_server_key

# File Paths
WORDLIST_DIR=/opt/wifi-launchpad/wordlists
CAPTURE_DIR=/opt/wifi-launchpad/captures
LOG_DIR=/var/log/wifi-launchpad
TEMP_DIR=/tmp/wifi-launchpad

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Security Settings
API_KEY=change-this-to-a-secure-key
SECRET_KEY=change-this-to-another-secure-key
ENABLE_CORS=false
ALLOWED_ORIGINS=http://localhost:3000

# Feature Flags
ENABLE_SANDBOX_MODE=true
ENABLE_AUTO_UPDATES=true
ENABLE_TELEMETRY=false
ENABLE_GPU_CRACKING=false

# Notification Settings
ENABLE_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Performance Tuning
MAX_CONCURRENT_SCANS=3
SCAN_CHANNEL_HOP_INTERVAL=0.5
HANDSHAKE_TIMEOUT=300
DEAUTH_BURST_COUNT=10
DEAUTH_BURST_DELAY=0.1