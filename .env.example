# SPECTRE Configuration
# Copy this file to .env and update with your values

# Database (run: docker compose up -d)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spectre_db
DB_USER=spectre
DB_PASSWORD=changeme
DB_CONNECT_TIMEOUT=5
COLLECTOR_NODE=local

# Paths (relative paths resolve from project root)
WORDLIST_DIR=wordlists
CAPTURE_DIR=captures
CASE_DIR=cases
LOG_DIR=logs
TEMP_DIR=/tmp/spectre

# Capture Tuning
HANDSHAKE_TIMEOUT=300
CAPTURE_WRITE_INTERVAL=2
DEAUTH_COUNT=5
DEAUTH_INTERVAL=10
MIN_QUALITY_SCORE=60.0
DEAUTH_PACKET_COUNT=10
DEAUTH_BURST_COUNT=5
DEAUTH_BURST_INTERVAL=5.0
DEAUTH_COOLDOWN=10.0

# Attack Technique Timeouts (seconds)
PMKID_TIMEOUT=30
DEAUTH_BROADCAST_TIMEOUT=60
DEAUTH_TARGETED_TIMEOUT=60
DEAUTH_AGGRESSIVE_TIMEOUT=90

# Scanner
SCAN_CHANNEL_HOP_INTERVAL=2.0
SCAN_WRITE_INTERVAL=5
SCAN_CHANNELS=1,6,11,36,40,44,48,149,153,157,161

# Crack
CRACK_TIMEOUT=600
CRACK_TIMEOUT_PER_FILE=300

# Remote GPU cracking (optional — offload hashcat to a GPU server via SSH)
CRACK_HOST=                        # e.g. user@gpu-server
CRACK_REMOTE_HASHCAT=hashcat       # hashcat binary path on remote
CRACK_REMOTE_TEMP_DIR=/tmp/spectre-crack
